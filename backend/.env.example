# Node.js Environment
NODE_ENV=development
PORT=3000
TRUST_PROXY=false

# CORS — comma-separated list of allowed origins. Use the Next.js frontend URL.
# Defaults: CORS_ORIGIN=http://localhost:3001 (Next.js dev server)
CORS_ORIGIN=http://localhost:3001
FRONTEND_ORIGIN=http://localhost:3001

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Database — Neon (or any Postgres). Pooled URL recommended for serverless.
DATABASE_URL=postgresql://user:password@ep-xxxxx.region.aws.neon.tech/neondb?sslmode=require

# Redis — Upstash.
# Set REDIS_URL to your Upstash TCP/TLS URL (rediss://default:<token>@<host>:6379).
# When REDIS_URL is set, REDIS_HOST / REDIS_PORT / REDIS_PASSWORD are ignored.
REDIS_URL=rediss://default:TOKEN@your-host.upstash.io:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Authentication
JWT_ACCESS_SECRET=your-access-secret-change-this-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-this-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cookie Security
COOKIE_SECRET=your-cookie-secret-change-this-in-production
COOKIE_SECURE=false

# File Upload
UPLOAD_MAX_SIZE=10mb
UPLOAD_DIR=./uploads

# Email (for future implementation)
EMAIL_SERVICE=
EMAIL_USER=
EMAIL_PASS=

# Frontend URL (used in outbound emails / share links)
FRONTEND_URL=http://localhost:3001

# Google OAuth (server-side redirect flow).
# In Google Cloud Console → APIs & Services → Credentials → your OAuth Client
# → Authorized redirect URIs, add EXACTLY the value of GOOGLE_REDIRECT_URI.
# For local dev that's http://localhost:3000/api/auth/google/callback
# For production it's https://<your-backend-domain>/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Supabase Storage (replaces local disk uploads — durable, CDN-backed).
# 1. Sign up at https://supabase.com (no credit card).
# 2. Create a project (region: Singapore to match Neon).
# 3. Storage → New bucket → name it (e.g. "uploads") → keep it PRIVATE.
# 4. Settings → API → copy Project URL and service_role key.
# 5. Rotate the service_role key before going to production.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt
SUPABASE_BUCKET=uploads
SUPABASE_SIGNED_URL_TTL_SECONDS=3600

# Optional: AI Service URLs (for integration with external AI services)
# EXTERNAL_DOCUMENT_SERVICE_URL=http://localhost:8000
# EXTERNAL_EMBEDDING_SERVICE_URL=
# EXTERNAL_LLM_SERVICE_URL=http://localhost:8000
# EXTERNAL_AUDIT_SERVICE_URL=
# EXTERNAL_API_KEY=

# Optional: Storage (for production, use AWS S3 or similar)
# STORAGE_PROVIDER=local # or aws, gcp, azure
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_REGION=

# Optional: Feature Flags
# FEATURE_WEBSOCKET_ENABLED=false
# FEATURE_RATE_LIMITING_ENABLED=true
# FEATURE_CACHING_ENABLED=true