# AIBridge frontend env

# The fixed-backend gateway. Used by `next.config.mjs` rewrites so the
# browser can keep calling relative `/api/...` paths.
BACKEND_URL=http://localhost:3000

# Same value, exposed to the browser for direct fetches that need an
# absolute URL (e.g. server components during SSR).
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000

# Public Google OAuth client ID. Safe to expose — it's only used to build
# the "Continue with Google" button URL. The secret lives only in fixed-backend.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
