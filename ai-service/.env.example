# ---------- Server ----------
APP_HOST=127.0.0.1
APP_PORT=8000
APP_ENV=development

# ---------- Paths (relative to ai-service/) ----------
DATA_DIR=./data
MODELS_DIR=./data/models
UPLOADS_DIR=./data/uploads
CACHE_DIR=./data/cache

# ---------- Qdrant (Cloud) ----------
# Get these from https://cloud.qdrant.io → your cluster → API Keys / Cluster URL.
# Local binary Qdrant is no longer supported. QDRANT_URL must include the port (default 6333).
QDRANT_URL=https://YOUR-CLUSTER-ID.australia-southeast1-0.gcp.cloud.qdrant.io:6333
QDRANT_API_KEY=replace-me

# ---------- Embeddings ----------
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32
EMBEDDING_MAX_SEQ_LENGTH=512

# ---------- Chunking ----------
CHUNK_SIZE=500
CHUNK_OVERLAP=80

# ---------- Document processing ----------
DOC_MAX_FILE_BYTES=26214400
DOC_MAX_FILES_PER_REQUEST=10
DOC_ALLOWED_EXTS=.pdf,.docx,.txt

# ---------- Groq LLM ----------
# GROQ_API_KEYS is a comma-separated pool for failover; GROQ_API_KEY is the
# legacy single-key entry point and is folded into the pool automatically.
GROQ_API_KEY=
GROQ_API_KEYS=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.2
GROQ_MAX_TOKENS=1024
GROQ_TIMEOUT_SECONDS=30

# ---------- Website Crawler ----------
CRAWLER_MAX_PAGES=8
CRAWLER_TIMEOUT_SECONDS=20
CRAWLER_USER_AGENT=AIBridge-Crawler/0.1 (+https://aibridge.local)

# ---------- Chatbot ----------
CHAT_TOP_K=6
CHAT_SCORE_THRESHOLD=0.30
CHAT_MAX_CONTEXT_CHARS=6000

# ---------- Supabase Storage (cardless durable upload storage) ----------
# ai-service fetches the original file from Supabase when re-processing.
# Mirror of the values in backend/.env — keep them in sync.
# 1. Sign up at https://supabase.com (no credit card).
# 2. Create a project (region: Singapore to match Neon).
# 3. Storage → New bucket → name it (e.g. "uploads") → keep it PRIVATE.
# 4. Settings → API → copy Project URL and service_role key.
# 5. Rotate the service_role key before going to production.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt
SUPABASE_BUCKET=uploads