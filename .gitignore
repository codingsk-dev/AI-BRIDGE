# Python
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtualenvs
.venv/
venv/
env/

# Test / build cache
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
build/
dist/
*.egg-info/

# Next.js
web/.next/
web/out/
web/node_modules/
teammate-frontend/.next/
teammate-frontend/out/
teammate-frontend/node_modules/
fixed-backend/node_modules/
fixed-backend/dist/

# Qdrant runtime state (no longer used — Qdrant Cloud now — but keep ignores
# harmless for the few local artifacts that may still exist on a checkout).
ai-service/data/qdrant/snapshots/
ai-service/data/qdrant/storage/
ai-service/.qdrant-initialized
ai-service/storage/

# Service runtime data (regenerated each session)
ai-service/data/cache/
ai-service/data/uploads/

# Embedding model: pulled by scripts/download_models.py on first install.
ai-service/data/models/

# Env / secrets — NEVER commit
.env
.env.*
**/.env
**/.env.*
!.env.example
!.env.*.example

# User's credentials scratchpad
info.txt
secrets.txt
*.local

# Logs
*.out
*.err
nohup.out

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# Frontend
frontend/frontend.out
frontend/frontend.err

# Node
**/node_modules/
**/.next/
**/.turbo/

# TypeScript build info
**/*.tsbuildinfo