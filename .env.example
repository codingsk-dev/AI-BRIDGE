# Node.js Environment
NODE_ENV=development
PORT=3000
TRUST_PROXY=false

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/aibridge?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Authentication
JWT_ACCESS_SECRET=your-access-secret-change-this-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-this-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cookie Security
COOKIE_SECRET=your-cookie-secret-change-this-in-production
COOKIE_SECURE=false

# File Upload
UPLOAD_MAX_SIZE=10mb
UPLOAD_DIR=./uploads

# Email (for future implementation)
EMAIL_SERVICE=
EMAIL_USER=
EMAIL_PASS=

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Optional: Monitoring
# SENTRY_DSN=
# ELASTIC_APM_SERVER_URL=
# ELASTIC_APM_SECRET_TOKEN=
# ELASTIC_APM_SERVICE_NAME=aibridge-backend
# ELASTIC_APM_ENVIRONMENT=development

# Optional: AI Service URLs (for integration with external AI services)
# EXTERNAL_DOCUMENT_SERVICE_URL=
# EXTERNAL_EMBEDDING_SERVICE_URL=
# EXTERNAL_LLM_SERVICE_URL=
# EXTERNAL_AUDIT_SERVICE_URL=
# EXTERNAL_API_KEY=

# Optional: Storage (for production, use AWS S3 or similar)
# STORAGE_PROVIDER=local # or aws, gcp, azure
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_REGION=

# Optional: Feature Flags
# FEATURE_WEBSOCKET_ENABLED=false
# FEATURE_RATE_LIMITING_ENABLED=true
# FEATURE_CACHING_ENABLED=true